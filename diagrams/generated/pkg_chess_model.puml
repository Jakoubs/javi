chess_model_BlackToMove --> chess_model_CastlingRights
chess_model_BlackToMove --> chess_model_Pos
chess_model_BlackToMove --> chess_model_GameState
chess_model_BlackToMove --> chess_model_Color
chess_model_GameRules --> chess_model_GameState
chess_model_GameRules --> chess_model_Move
chess_model_GameRules --> chess_model_GameStatus
chess_model_MoveGenerator --> chess_model_Move
chess_model_MoveGenerator --> chess_model_GameState
chess_model_MoveGenerator --> chess_model_Pos
chess_model_MoveGenerator --> chess_model_Color
chess_model_MoveGenerator --> chess_model_Board
